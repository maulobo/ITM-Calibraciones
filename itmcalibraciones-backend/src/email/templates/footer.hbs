        </tr>
        {{/if}}

        <!-- FOOTER INFO -->
        <tr>
          <td style="background-color:#f8fafc;border-top:1px solid #e2e8f0;padding:18px 32px;font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#6b7280;text-align:center;line-height:1.9;">
            <strong style="display:block;color:#1e4470;font-size:12px;margin-bottom:4px;">Calibraciones ITM S.A.</strong>
            Almafuerte 357, Bahía Blanca, Buenos Aires &nbsp;&middot;&nbsp; CUIT 30-71167690-9<br />
            xxxxxxxxxx &nbsp;&middot;&nbsp; xxxxxxxxxx
